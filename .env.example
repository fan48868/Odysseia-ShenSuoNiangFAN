# .env.example - 环境变量示例文件
# 将此文件复制为 .env 并填入你的实际值。

# 你的 Discord 机器人令牌
DISCORD_TOKEN="YOUR_DISCORD_TOKEN_HERE"

# (可选) 用于在开发时快速同步斜杠命令的服务器（公会）ID
# 如果留空，命令将进行全局同步（可能需要长达一小时才能生效）
GUILD_ID="YOUR_DEVELOPMENT_GUILD_ID_HERE"

# --- 新增：权限控制 ---
# 拥有此命令访问权限的开发者用户ID，多个ID请用逗号分隔
DEVELOPER_USER_IDS="YOUR_USER_ID_1,YOUR_USER_ID_2"

# 拥有此命令访问权限的身份组ID，多个ID请用逗号分隔
ADMIN_ROLE_IDS="YOUR_ROLE_ID_1,YOUR_ROLE_ID_2"

# --- Gemini AI 配置 ---
# (可选) 自定义 Gemini API 端点，例如 AI 网关。如果留空，将直连 Google 官方服务。
GEMINI_API_BASE_URL=""
# (可选) 如果您的网关需要一个特定的 API 密钥，请在此处填写。直连时通常不需要。
GEMINI_API_KEYS=""

# Google Gemini API 密钥 (用于AI对话功能)
# 多个密钥请直接换行，并用英文双引号 "..." 将所有密钥包裹起来
GOOGLE_API_KEYS_LIST="
YOUR_GEMINI_API_KEY_1
YOUR_GEMINI_API_KEY_2
"

# --- 功能开关 ---
# 是否启用聊天功能 (True/False)
# 这是一个全局紧急开关，可在不修改数据库的情况下快速禁用整个聊天功能
CHAT_ENABLED=True

# 是否记录AI完整的上下文日志 (true/false)
# 用于调试，会记录发送给AI的完整上下文
LOG_AI_FULL_CONTEXT=true

# --- 工具加载器配置 ---
# 禁用的工具模块列表（文件名，不含.py扩展名），多个用逗号分隔
DISABLED_TOOLS="get_yearly_summary"

# --- Gradio TTS 配置 ---
# 新版 TTS 工具使用的 Gradio / Ngrok 地址（不要硬编码在代码里）
GRADIO_API_URL="https://your-gradio-or-ngrok-url.ngrok-free.dev"

# --- 类脑币系统 ---
# 在指定服务器发帖可获得奖励的服务器ID，多个用逗号隔开
COIN_REWARD_GUILD_IDS="YOUR_GUILD_ID_1,YOUR_GUILD_ID_2"

# --- Discord OAuth 配置 ---
# 用于Web界面的Discord OAuth认证
VITE_DISCORD_CLIENT_ID="YOUR_DISCORD_CLIENT_ID"
DISCORD_CLIENT_SECRET="YOUR_DISCORD_CLIENT_SECRET"

# --- Gemini 调试配置 ---
# 是否记录详细的Gemini处理过程
LOG_DETAILED_GEMINI_PROCESS=True

# --- GROK 生图端点配置 ---
GROK_IMAGINE_API_KEY=""    #填写vercel密钥。也可以去改别的渠道

# --- 论坛帖子语义搜索 ---
# 需要进行RAG索引的论坛频道ID，多个用逗号隔开
# 这些频道的帖子会被索引到向量数据库，用于语义搜索
FORUM_SEARCH_CHANNEL_IDS="YOUR_FORUM_CHANNEL_ID_1,YOUR_FORUM_CHANNEL_ID_2"

# --- 自定义 Gemini 端点配置 ---
# (可选) 自定义 Gemini API 端点，例如公益站
CUSTOM_GEMINI_URL=""
CUSTOM_GEMINI_API_KEY=""

SUMMARY_MODEL='deepseek-chat'  # 记忆总结模型

# --- PostgreSQL 数据库配置 ---
POSTGRES_DB="your_database_name"
POSTGRES_USER="your_username"
POSTGRES_PASSWORD="your_password"
DB_PORT=5432

VPS_MODE=false  # 为小宽带vps设计。强制将图片压缩到1mb以下，加快回复速度


# --- 自定义 Openai 端点配置 ---
DEEPSEEK_URL="https://api.deepseek.com/"
DEEPSEEK_API_KEY=""
MOONSHOT_URL="https://api.moonshot.cn/v1"
MOONSHOT_API_KEY=""   #支持多个key轮换

CUSTOM_MODEL_URL=''   #支持自定义openai格式模型，可在聊天设置中热切换
CUSTOM_MODEL_API_KEY=''
CUSTOM_MODEL_NAME=''
CUSTOM_MODEL_ENABLE_VISION='true'  # 启动custom外置识图功能(模型自身不能读图时开启)需要配置MOONSHOT_API_KEY
CUSTOM_MODEL_ENABLE_VIDEO_INPUT='false'

# --- kimi 公益站端点配置 ---
CUSTOM_MOONSHOT_URL=""
CUSTOM_MOONSHOT_API_KEY=""
CUSTOM_MOONSHOT_MODEL_NAME="" #公益站自定义模型名
IS_NV_MODEL=True   #大多公益站使用nvidia的模型，需要特殊的关闭思考模式的方式